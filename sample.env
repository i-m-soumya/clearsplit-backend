# copy this file to `.env` and fill in real values
# do NOT commit your actual credentials

PORT=5000

DB_HOST=your-hostname
DB_PORT=3306
DB_USER=your-db-user
DB_PASSWORD=your-db-password
DB_NAME=your-db-name

DB_SSL=false       # set to true if using SSL
DB_SSL_CA=path/to/ca.pem

JWT_SECRET=replace-with-a-strong-secret

APP_NAME=ClearSplit
APP_ENV=development
API_BASE_URL=http://localhost:5000

# Email configuration for OTP (using Mailtrap for testing)
EMAIL_HOST=sandbox.smtp.mailtrap.io
EMAIL_PORT=2525
EMAIL_USER=update-with-mailtrap-username
EMAIL_PASS=update-with-mailtrap-password
